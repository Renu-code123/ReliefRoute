ANTHROPIC_API_KEY=sk-ant-your-key-here
PORT=3001
MESH_WS_PORT=8765
JWT_SECRET=change_this_in_production
DEFAULT_LANGUAGE=en
EQUITY_THRESHOLD=0.40
NODE_ENV=development

# Disaster incidents
NDMA_API_KEY=your_ndma_key_here
RELIEFWEB_APP_NAME=reliefroute

# Routing and road conditions
ORS_API_KEY=your_openrouteservice_key_here

# Polling intervals in milliseconds
POLL_INCIDENTS_MS=900000       # 15 minutes
POLL_WEATHER_MS=1800000        # 30 minutes
POLL_POPULATION_MS=3600000     # 60 minutes

# Offline fallback threshold
API_FAIL_THRESHOLD=3

# Google Gemini API FOR Chatbot
GOOGLE_API_KEY=your_api_key_here
